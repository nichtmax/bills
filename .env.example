# ---------------------------------------------------------------------------
# bills - unified bill downloader configuration
# Copy to .env and fill in. All paths are container-internal.
# ---------------------------------------------------------------------------

# Which addons are enabled (comma-separated)
BILLS_ADDONS=vodafone,cursor,zai

# Scheduler
BILLS_RUN_ON_START=false
BILLS_TZ=Europe/Berlin
# Per-addon cron (defaults preserve previous cadence)
BILLS_VODAFONE_CRON=0 6 * * 1
BILLS_CURSOR_CRON=0 6 1 * *

# Paths (inside the container)
BILLS_DOWNLOAD_DIR=/downloads
BILLS_CONFIG_DIR=/config

# Web UI (served by the bills app alongside the scheduler)
BILLS_WEB_PORT=8080
BILLS_WEB_SECRET=change-me
BILLS_WEB_USERNAME=admin
BILLS_WEB_PASSWORD=

# Web UI auth: set BILLS_WEB_PASSWORD to require login (username defaults to admin).

# Browser (Playwright Chromium, launched in-process per addon run)
BILLS_HEADLESS=true
FLARESOLVERR_ENABLED=false
FLARESOLVERR_URL=http://flaresolverr:8191

# SMTP (shared by all addons)
BILLS_SMTP_SERVER=
BILLS_SMTP_PORT=587
BILLS_EMAIL_FROM=
BILLS_EMAIL_PASSWORD=
BILLS_EMAIL_TO=

# Invoice email templates (placeholders: {provider}, {addon}, {filename}, {date}, {number}, {recipient})
BILLS_MAIL_SUBJECT={provider} invoice: {filename}
BILLS_MAIL_BODY=Attached is the latest {provider} invoice: {filename}
Date: {date}
Invoice number: {number}

# --- Vodafone ---
VODAFONE_USERNAME=
VODAFONE_PASSWORT=

# --- Cursor ---
# Session cookies exported from a logged-in browser (JSON array) OR a file path.
CURSOR_SESSION_COOKIES=
CURSOR_SESSION_COOKIES_FILE=/config/cursor-session-cookies.json
# Optional: skip Cursor login and go straight to the Stripe billing portal.
CURSOR_STRIPE_PORTAL_URL=

# --- Proton VPN ---
PROTON_USERNAME=
PROTON_PASSWORT=
# Optional fallback: export session cookies from account.proton.me after login.
PROTON_SESSION_COOKIES=
PROTON_SESSION_COOKIES_FILE=/config/proton-session-cookies.json

# --- Z.ai ---
ZAI_API_KEY=
ZAI_BEARER_TOKEN=
ZAI_EMAIL=
ZAI_PASSWORD=
# Optional fallback: export session cookies from a logged-in browser session.
ZAI_SESSION_COOKIES=
ZAI_SESSION_COOKIES_FILE=/config/zai-session-cookies.json

# Git (used by the bootstrap to clone + pull this repo; public, no token needed)
# The entrypoint installs git automatically when it is missing in the container image.
BILLS_REPO=github.com/nichtmax/bills
