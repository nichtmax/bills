# ---------------------------------------------------------------------------
# bills - unified bill downloader configuration
# Copy to .env and fill in. All paths are container-internal.
# ---------------------------------------------------------------------------

# Which addons are enabled (comma-separated)
BILLS_ADDONS=vodafone,cursor

# Scheduler
BILLS_RUN_ON_START=false
BILLS_TZ=Europe/Berlin
# Per-addon cron (defaults preserve previous cadence)
BILLS_VODAFONE_CRON=0 6 * * 1
BILLS_CURSOR_CRON=0 6 1 * *

# Paths (inside the container)
BILLS_DOWNLOAD_DIR=/downloads
BILLS_CONFIG_DIR=/config

# Web UI (served by the bills app alongside the scheduler)
BILLS_WEB_PORT=8080
BILLS_WEB_SECRET=change-me

# Browser (Playwright Chromium, launched in-process per addon run)
BILLS_HEADLESS=true
FLARESOLVERR_ENABLED=false
FLARESOLVERR_URL=http://flaresolverr:8191

# SMTP (shared by all addons)
BILLS_SMTP_SERVER=
BILLS_SMTP_PORT=587
BILLS_EMAIL_FROM=
BILLS_EMAIL_PASSWORD=
BILLS_EMAIL_TO=

# --- Vodafone ---
VODAFONE_USERNAME=
VODAFONE_PASSWORT=

# --- Cursor ---
# Session cookies exported from a logged-in browser (JSON array) OR a file path.
CURSOR_SESSION_COOKIES=
CURSOR_SESSION_COOKIES_FILE=/config/cursor-session-cookies.json
# Optional: skip Cursor login and go straight to the Stripe billing portal.
CURSOR_STRIPE_PORTAL_URL=

# Git (used by the bootstrap to clone + pull this repo; public, no token needed)
BILLS_REPO=github.com/nichtmax/bills
